{
  "manifest_version": 3,
  "name": "Page Connect",
  "version": "1.0.0",
  "description": "Opens a URL at a precise time, adjusted for measured network latency.",
  "permissions": ["storage", "tabs", "alarms", "windows", "power"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Page Connect",
    "default_popup": "popup.html"
  }
}
